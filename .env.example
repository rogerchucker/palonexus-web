# PaloNexus docs deployment — CI ONLY.
#
# These values are consumed exclusively by GitHub Actions
# (.github/workflows/docs-ci-deploy.yml). Do NOT deploy from a laptop and do NOT put
# real secrets in this file — publishing is CI-only by design.
#
# Configure these as GitHub Actions secrets, preferably scoped to the "production"
# Environment (Settings -> Environments -> production), so a deploy can additionally
# require a human reviewer:
#
#   CLOUDFLARE_API_TOKEN
#     A scoped Cloudflare API token (NOT a global key) with, on the account that owns
#     the `palonexus-docs` worker and the palonexus.ai zone:
#       - Account  > Workers Scripts   : Edit
#       - Zone     > Workers Routes     : Edit   (zone: palonexus.ai)
#       - Account  > Account Settings   : Read
#       - Zone     > Zone               : Read   (zone: palonexus.ai)
#
#   CLOUDFLARE_ACCOUNT_ID
#     The Cloudflare account id that owns the `palonexus-docs` worker.
#
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
