---
import { brand, cta, navLinks } from '../../../shared/site-nav.mjs';

interface Props {
	/**
	 * 'homepage' -> in-page hash links (#solutions), used on the homepage itself.
	 * 'absolute' (default) -> homepage-qualified hash links (/#solutions), used on
	 * every other page that renders this nav (request-changes, thanks).
	 */
	context?: 'homepage' | 'absolute';
}

const { context = 'absolute' } = Astro.props;
const links = navLinks(context);
---

<div class="nav-bar">
	<header class="nav" aria-label="Primary navigation">
		<a class="brand" href={brand.href} aria-label={`${brand.label} home`}>
			<span class="brand-mark" aria-hidden="true">{brand.mark}</span>
			<span>{brand.label}</span>
		</a>
		<nav class="nav-links" aria-label="Page sections">
			{links.map((link) => <a href={link.href}>{link.label}</a>)}
		</nav>
		<a class="nav-cta" href={cta.href}>{cta.label}</a>
	</header>
</div>
