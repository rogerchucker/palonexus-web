---
import type { ClosingData } from '../../content.config';

interface Props {
	data: ClosingData;
}

const { data } = Astro.props;
---

<section class="closing">
	<p class="eyebrow">{data.eyebrow}</p>
	<h2>{data.heading}</h2>
	<div class="closing-actions">
		<a class="button primary" href={data.cta.href}>{data.cta.label}</a>
		{
			data.secondaryCta && (
				<a class="button secondary" href={data.secondaryCta.href}>
					{data.secondaryCta.label}
				</a>
			)
		}
	</div>
</section>
