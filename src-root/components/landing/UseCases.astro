---
import type { UseCasesData } from '../../content.config';

interface Props {
	data: UseCasesData;
}

const { data } = Astro.props;
---

<section class="section use-cases">
	<div class="section-heading">
		<p class="eyebrow">{data.eyebrow}</p>
		<h2>{data.heading}</h2>
	</div>
	<div class="use-case-list">
		{
			data.items.map((item) => (
				<article>
					<span aria-hidden="true" />
					<p>{item}</p>
				</article>
			))
		}
	</div>
</section>
