---
import '../styles/theme.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta
			name="description"
			content="PaloNexus is the authorization and accountability layer for AI agents: accountable ownership, authority-bound delegation, just-in-time access, lifecycle-linked revocation, and a verifiable authority trail."
		/>
		<meta name="generator" content={Astro.generator} />
		<title>PaloNexus | Give AI agents authority without standing access</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: var(--pn-bg);
		color: var(--pn-text);
		font-family: var(--pn-font);
	}

	* {
		box-sizing: border-box;
	}
</style>
