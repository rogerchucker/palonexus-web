---
import '../styles/landing.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta
			name="description"
			content="PaloNexus helps enterprises build, govern, and scale AI agents with agent solutions, agent platforms, and development frameworks."
		/>
		<meta name="generator" content={Astro.generator} />
		<title>PaloNexus | Build, govern, and scale enterprise AI agents</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: #f6f4ef;
		color: #121413;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	* {
		box-sizing: border-box;
	}
</style>
