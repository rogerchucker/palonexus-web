---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
---

<Layout>
	<Nav />
	<div class="site-shell">
		<main class="request-access">
			<p class="eyebrow">Request received</p>
			<h1>Thanks — your request is in.</h1>
			<p class="request-lede">
				We have received your integration or change request. PaloNexus delivers requested and
				agreed-upon enhancements, changes, and fixes within a 2-business-day turnaround, subject to
				adjustment based on market conditions. In the meantime, the documentation covers the
				authorization model, the quickstart, and how PaloNexus fits alongside your runtime or
				sandbox.
			</p>
			<div class="hero-actions">
				<a class="button primary" href="/docs/">Read the docs</a>
				<a class="button secondary" href="/">Back to the homepage</a>
			</div>
		</main>
	</div>
</Layout>
