---
const solutions = [
	{
		kicker: 'Agents',
		title: 'Purpose-built agents for critical work',
		description:
			'Deploy SRE, DevOps, SecOps, support, and operations agents that understand context, follow policy, and execute inside clear boundaries.',
		items: ['Incident response', 'Deployment operations', 'Change review', 'Runbook automation'],
	},
	{
		kicker: 'Platforms for agents',
		title: 'The control layer for agent ecosystems',
		description:
			'Connect every agent through a gateway, registry, identity layer, policy engine, observability plane, and audit trail.',
		items: ['Agent gateway', 'Registry and lifecycle', 'Identity and access', 'Runtime audit'],
	},
	{
		kicker: 'Frameworks for agents',
		title: 'Repeatable systems for building agents',
		description:
			'Give teams development frameworks for agent orchestration, evaluations, tool contracts, guardrails, and reusable execution patterns.',
		items: ['Development patterns', 'Evaluation loops', 'Tool interfaces', 'Cost-aware orchestration'],
	},
];

const useCases = [
	'Resolve incidents with agents that can inspect telemetry, propose remediations, and request approval before acting.',
	'Automate deployment workflows while keeping infrastructure changes visible, reversible, and policy-bound.',
	'Review risky changes with agents that summarize blast radius, dependencies, and operational readiness.',
	'Launch an internal agent marketplace with ownership, access scope, and lifecycle metadata for every agent.',
];

const trustControls = [
	'Scoped access for each agent, tool, workflow, and environment.',
	'Human approvals where autonomy needs a deliberate checkpoint.',
	'Runtime policy that evaluates context before actions execute.',
	'Complete action logs for security, operations, and leadership review.',
];
---

<main class="site-shell">
	<header class="nav" aria-label="Primary navigation">
		<a class="brand" href="/" aria-label="PaloNexus home">
			<span class="brand-mark" aria-hidden="true">PN</span>
			<span>PaloNexus</span>
		</a>
		<nav class="nav-links" aria-label="Page sections">
			<a href="#solutions">Solutions</a>
			<a href="#platform">Platform</a>
			<a href="#governance">Governance</a>
		</nav>
		<a class="nav-cta" href="mailto:hello@palonexus.ai">Request access</a>
	</header>

	<section class="hero">
		<div class="hero-copy">
			<p class="eyebrow">Agentic AI operating layer</p>
			<h1>Build, govern, and scale enterprise AI agents.</h1>
			<p class="hero-lede">
				PaloNexus helps teams deploy purpose-built agents, operate the platform that governs
				them, and use frameworks that make agent development repeatable.
			</p>
			<div class="hero-actions" aria-label="Primary actions">
				<a class="button primary" href="mailto:hello@palonexus.ai">Request access</a>
				<a class="button secondary" href="#solutions">Explore solutions</a>
			</div>
		</div>

		<div class="hero-panel" aria-label="PaloNexus platform flow">
			<div class="flow-row source">
				<span>SRE agent</span>
				<span>DevOps agent</span>
				<span>SecOps agent</span>
			</div>
			<div class="flow-core">
				<p>PaloNexus control layer</p>
				<div class="core-grid">
					<span>Identity</span>
					<span>Policy</span>
					<span>Registry</span>
					<span>Audit</span>
				</div>
			</div>
			<div class="flow-row target">
				<span>Clouds</span>
				<span>Tools</span>
				<span>Data</span>
				<span>Workflows</span>
			</div>
		</div>
	</section>

	<section id="solutions" class="section">
		<div class="section-heading">
			<p class="eyebrow">Three categories of solutions</p>
			<h2>Everything enterprises need to move from experiments to agentic operations.</h2>
		</div>

		<div class="solution-grid">
			{
				solutions.map((solution) => (
					<article class="solution-card">
						<p class="card-kicker">{solution.kicker}</p>
						<h3>{solution.title}</h3>
						<p>{solution.description}</p>
						<ul>
							{solution.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</section>

	<section class="why-now">
		<div>
			<p class="eyebrow">Why now</p>
			<h2>Agents are becoming operational actors, not just chat interfaces.</h2>
		</div>
		<p>
			As agents call APIs, trigger workflows, inspect infrastructure, and reason across systems,
			teams need a common operating model for identity, guardrails, lifecycle, and measurable
			outcomes. PaloNexus is built for that shift.
		</p>
	</section>

	<section id="platform" class="section platform">
		<div class="section-heading narrow">
			<p class="eyebrow">Platform architecture</p>
			<h2>Route every agent action through a governed control layer.</h2>
		</div>
		<div class="architecture">
			<div class="arch-column">
				<h3>Agents</h3>
				<p>Task-specific agents for engineering, operations, security, and support teams.</p>
			</div>
			<div class="arch-connector" aria-hidden="true">-&gt;</div>
			<div class="arch-column core">
				<h3>PaloNexus</h3>
				<p>Gateway, registry, identity, policy, observability, and audit in one control layer.</p>
			</div>
			<div class="arch-connector" aria-hidden="true">-&gt;</div>
			<div class="arch-column">
				<h3>Enterprise systems</h3>
				<p>Cloud providers, source control, CI/CD, ticketing, data platforms, and internal APIs.</p>
			</div>
		</div>
	</section>

	<section class="section use-cases">
		<div class="section-heading">
			<p class="eyebrow">Use cases</p>
			<h2>Start where agents can reduce operational load without hiding accountability.</h2>
		</div>
		<div class="use-case-list">
			{
				useCases.map((useCase) => (
					<article>
						<span aria-hidden="true"></span>
						<p>{useCase}</p>
					</article>
				))
			}
		</div>
	</section>

	<section id="governance" class="section governance">
		<div class="governance-copy">
			<p class="eyebrow">Trust and governance</p>
			<h2>Autonomy needs a boundary every team can understand.</h2>
			<p>
				PaloNexus makes agent actions visible and governable from the start, so security teams
				can say yes to adoption without losing control of access, approvals, or auditability.
			</p>
		</div>
		<ul class="control-list">
			{
				trustControls.map((control) => (
					<li>{control}</li>
				))
			}
		</ul>
	</section>

	<section class="closing">
		<p class="eyebrow">Build your agentic operating model</p>
		<h2>Design your agentic operating model with PaloNexus.</h2>
		<a class="button primary" href="mailto:hello@palonexus.ai">Request access</a>
	</section>
</main>

<style>
	.site-shell {
		min-height: 100vh;
		overflow: hidden;
	}

	.nav {
		align-items: center;
		display: flex;
		gap: 24px;
		justify-content: space-between;
		margin: 0 auto;
		max-width: 1180px;
		padding: 24px 28px;
	}

	.brand,
	.nav-links,
	.hero-actions {
		align-items: center;
		display: flex;
	}

	.brand {
		color: #121413;
		font-size: 18px;
		font-weight: 760;
		gap: 10px;
		text-decoration: none;
	}

	.brand-mark {
		align-items: center;
		background: #14213d;
		border-radius: 8px;
		color: #f8f5ef;
		display: inline-flex;
		font-size: 12px;
		height: 34px;
		justify-content: center;
		width: 34px;
	}

	.nav-links {
		gap: 28px;
	}

	.nav-links a,
	.nav-cta,
	.button {
		border-radius: 8px;
		color: #28302e;
		font-size: 14px;
		font-weight: 680;
		text-decoration: none;
	}

	.nav-links a {
		padding: 8px 0;
	}

	.nav-cta,
	.button {
		border: 1px solid #26322f;
		display: inline-flex;
		justify-content: center;
		min-height: 44px;
		padding: 12px 18px;
	}

	.hero {
		display: grid;
		gap: 48px;
		grid-template-columns: minmax(0, 1fr) minmax(360px, 0.72fr);
		margin: 0 auto;
		max-width: 1180px;
		padding: 88px 28px 72px;
	}

	.hero-copy {
		max-width: 720px;
	}

	.eyebrow,
	.card-kicker {
		color: #b44d29;
		font-size: 13px;
		font-weight: 800;
		margin: 0 0 14px;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		color: #101715;
		font-size: clamp(48px, 7vw, 86px);
		line-height: 0.98;
		margin-bottom: 26px;
		max-width: 850px;
	}

	h2 {
		color: #111614;
		font-size: clamp(32px, 4vw, 54px);
		line-height: 1.04;
		margin-bottom: 0;
	}

	h3 {
		color: #111614;
		font-size: 22px;
		line-height: 1.15;
		margin-bottom: 14px;
	}

	p {
		color: #4d5651;
		font-size: 17px;
		line-height: 1.65;
	}

	.hero-lede {
		font-size: 21px;
		line-height: 1.55;
		margin-bottom: 32px;
		max-width: 680px;
	}

	.hero-actions {
		flex-wrap: wrap;
		gap: 12px;
	}

	.button.primary {
		background: #121413;
		color: #fffaf2;
	}

	.button.secondary {
		background: #fffaf2;
		color: #121413;
	}

	.hero-panel {
		align-self: center;
		background: #141817;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 8px;
		box-shadow: 0 30px 80px rgba(18, 20, 19, 0.22);
		color: #f8f5ef;
		display: grid;
		gap: 20px;
		min-height: 430px;
		padding: 24px;
	}

	.flow-row,
	.core-grid {
		display: grid;
		gap: 10px;
	}

	.flow-row.source {
		grid-template-columns: repeat(3, 1fr);
	}

	.flow-row.target,
	.core-grid {
		grid-template-columns: repeat(2, 1fr);
	}

	.flow-row span,
	.core-grid span {
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 8px;
		color: #e8e0d1;
		font-size: 13px;
		font-weight: 720;
		padding: 13px;
		text-align: center;
	}

	.flow-core {
		background: #f2c166;
		border-radius: 8px;
		color: #121413;
		padding: 22px;
	}

	.flow-core p {
		color: #121413;
		font-size: 18px;
		font-weight: 800;
		margin-bottom: 16px;
		text-align: center;
	}

	.core-grid span {
		border-color: rgba(18, 20, 19, 0.18);
		color: #121413;
	}

	.section {
		margin: 0 auto;
		max-width: 1180px;
		padding: 76px 28px;
	}

	.section-heading {
		display: grid;
		gap: 30px;
		grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
		margin-bottom: 34px;
	}

	.section-heading.narrow {
		display: block;
		max-width: 760px;
	}

	.solution-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(3, 1fr);
	}

	.solution-card,
	.arch-column,
	.use-case-list article {
		background: #fffaf2;
		border: 1px solid #ded6c8;
		border-radius: 8px;
	}

	.solution-card {
		padding: 28px;
	}

	.solution-card p {
		margin-bottom: 22px;
	}

	.solution-card ul,
	.control-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.solution-card li {
		border-top: 1px solid #e8dfd0;
		color: #252b29;
		font-size: 14px;
		font-weight: 720;
		padding: 12px 0;
	}

	.why-now {
		align-items: start;
		background: #14213d;
		color: #fffaf2;
		display: grid;
		gap: 40px;
		grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1fr);
		margin: 56px 0;
		padding: 72px max(28px, calc((100vw - 1124px) / 2));
	}

	.why-now h2,
	.why-now p {
		color: #fffaf2;
	}

	.why-now .eyebrow {
		color: #f2c166;
	}

	.platform {
		padding-top: 56px;
	}

	.architecture {
		align-items: stretch;
		display: grid;
		gap: 16px;
		grid-template-columns: 1fr auto 1.15fr auto 1fr;
		margin-top: 34px;
	}

	.arch-column {
		padding: 28px;
	}

	.arch-column.core {
		background: #121413;
		border-color: #121413;
	}

	.arch-column.core h3,
	.arch-column.core p {
		color: #fffaf2;
	}

	.arch-connector {
		align-self: center;
		color: #b44d29;
		font-size: 24px;
		font-weight: 900;
	}

	.use-case-list {
		display: grid;
		gap: 14px;
		grid-template-columns: repeat(2, 1fr);
	}

	.use-case-list article {
		display: grid;
		gap: 16px;
		grid-template-columns: 14px 1fr;
		padding: 24px;
	}

	.use-case-list span {
		background: #3f7d6a;
		border-radius: 999px;
		height: 14px;
		margin-top: 8px;
		width: 14px;
	}

	.use-case-list p {
		margin-bottom: 0;
	}

	.governance {
		align-items: start;
		display: grid;
		gap: 42px;
		grid-template-columns: minmax(0, 0.9fr) minmax(340px, 0.7fr);
	}

	.governance-copy p {
		margin-top: 22px;
	}

	.control-list {
		background: #111614;
		border-radius: 8px;
		padding: 10px 24px;
	}

	.control-list li {
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		color: #fffaf2;
		font-size: 16px;
		line-height: 1.55;
		padding: 18px 0;
	}

	.control-list li:last-child {
		border-bottom: 0;
	}

	.closing {
		background: #efe8dc;
		margin-top: 56px;
		padding: 88px 28px;
		text-align: center;
	}

	.closing h2 {
		margin: 0 auto 28px;
		max-width: 800px;
	}

	@media (max-width: 900px) {
		.nav {
			align-items: flex-start;
			flex-direction: column;
		}

		.nav-links {
			flex-wrap: wrap;
			gap: 18px;
		}

		.hero,
		.section-heading,
		.why-now,
		.governance {
			grid-template-columns: 1fr;
		}

		.hero {
			padding-top: 52px;
		}

		.hero-panel {
			min-height: 0;
		}

		.solution-grid,
		.use-case-list {
			grid-template-columns: 1fr;
		}

		.architecture {
			grid-template-columns: 1fr;
		}

		.arch-connector {
			transform: rotate(90deg);
			justify-self: center;
		}
	}

	@media (max-width: 560px) {
		.nav,
		.hero,
		.section,
		.closing {
			padding-left: 20px;
			padding-right: 20px;
		}

		h1 {
			font-size: 44px;
		}

		.hero-lede {
			font-size: 18px;
		}

		.flow-row.source,
		.flow-row.target,
		.core-grid {
			grid-template-columns: 1fr;
		}

		.nav-cta,
		.button {
			width: 100%;
		}
	}
</style>
